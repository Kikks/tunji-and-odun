---
import { wedding } from "../config/wedding.ts";
---

<section class="thank-you section text-center" aria-label="Thank you">
  <div class="thank-you__card container-narrow text-center rounded-lg bg-bg-deep shadow-lg">
    <p class="eyebrow">{wedding.thankYou.heading}</p>
    <h2 class="script thank-you__names text-accent leading-none">
      {wedding.couple.one} &amp; {wedding.couple.two}
    </h2>
    <p class="thank-you__body text-ink-soft italic max-w-md mx-auto">{wedding.thankYou.body}</p>
    <span class="divider"></span>
  </div>
</section>

<style>
  /* Radial-gradient background overlaid on cream — gradient stops aren't a
     Tailwind utility shape. Also overrides .section's padding-bottom. */
  .thank-you {
    background:
      radial-gradient(circle at 50% 100%, rgba(200, 162, 75, 0.16), transparent 70%),
      var(--color-bg);
    padding-bottom: clamp(var(--space-9), 16vw, var(--space-10));
  }

  /* Fluid card padding — clamp() not expressible as a utility. */
  .thank-you__card {
    padding: clamp(var(--space-7), 10vw, var(--space-9)) clamp(var(--space-5), 6vw, var(--space-7));
  }

  .thank-you__names {
    font-size: clamp(3rem, 9vw, 5.5rem);
    margin: var(--space-4) 0 var(--space-5);
  }
</style>

<script>
  import { getGsap, prefersReducedMotion } from "../lib/gsap.ts";

  function run() {
    if (prefersReducedMotion()) return;
    const { gsap } = getGsap();
    gsap.from(".thank-you__card > *", {
      scrollTrigger: { trigger: ".thank-you__card", start: "top 80%" },
      opacity: 0,
      y: 24,
      duration: 0.9,
      ease: "power3.out",
      stagger: 0.12,
    });
  }

  if (document.readyState !== "loading") run();
  else document.addEventListener("DOMContentLoaded", run);
</script>
