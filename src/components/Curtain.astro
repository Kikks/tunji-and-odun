---
import { Pointer } from "@lucide/astro";

// Intro curtain overlay: closed image + nudge → click starts video → video ends → fade overlay away.
// The OPEN curtain image lives on the Invitation section below, so when this overlay fades out,
// the open curtain is revealed behind with the invitation text fading in.
const curtainImage = "/assets/curtain-closed.jpg";
const curtainVideo = "/assets/curtain-video.mp4";
const audioSrc = "/assets/bg-music.mp3";
---

<div
	class='curtain fixed inset-0 z-50 overflow-hidden cursor-pointer h-dvh bg-bg'
	id='curtain'
	data-state='closed'
	aria-hidden='false'
>
	<img
		class='curtain__image absolute inset-0 w-full! h-full! object-cover'
		id='curtain-image'
		src={curtainImage}
		alt='Closed theatre curtain'
		fetchpriority='high'
	/>
	<video
		class='curtain__video absolute inset-0 w-full! h-full! object-cover'
		id='curtain-video'
		src={curtainVideo}
		muted
		playsinline
		preload='auto'
		aria-hidden='true'></video>

	<button
		class='curtain__nudge h-40 w-40 rounded-full absolute bg-black backdrop-blur-xs left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col justify-center items-center gap-2 text-bg font-serif'
		id='curtain-nudge'
		type='button'
		aria-label='Tap to continue'
	>
		<span
			class='curtain__nudge-icon w-14 h-14 rounded-full border border-bg/75 grid place-items-center backdrop-blur-[3px] bg-white/20'
			aria-hidden='true'
		>
			<Pointer class='text-white' />
		</span>
		<span class='text-white'>Tap to continue</span>
	</button>
</div>

<script define:vars={{ audioSrc }}>
	// window.__weddingAudioSrc = audioSrc;
</script>

<style>
	/* Bare overlay needs a deep almost-black background and an opacity transition
     keyed off [data-state]. The text-shadow on the nudge label likewise has no
     comfortable utility expression. The state machine and pulse keyframes stay
     here because they're intrinsically linked. */
	.curtain {
		transition: opacity 1.1s var(--ease-out);
	}

	.curtain[data-state="hidden"] {
		opacity: 0;
		pointer-events: none;
	}

	.curtain__video {
		opacity: 0;
		transition: opacity 0.25s var(--ease-out);
	}

	.curtain[data-state="playing"] .curtain__video,
	.curtain[data-state="hidden"] .curtain__video {
		opacity: 1;
	}

	.curtain[data-state="playing"] .curtain__image,
	.curtain[data-state="hidden"] .curtain__image {
		opacity: 0;
		transition: opacity 0.15s linear 0.05s;
	}

	.curtain__nudge {
		text-shadow: 0 2px 14px rgba(0, 0, 0, 0.55);
		transition: opacity 0.35s var(--ease-out);
	}

	.curtain[data-state="playing"] .curtain__nudge,
	.curtain[data-state="hidden"] .curtain__nudge {
		opacity: 0;
		pointer-events: none;
	}

	@media (prefers-reduced-motion: no-preference) {
		.curtain__nudge-icon {
			animation: curtain-pulse 2.2s ease-in-out infinite;
		}
		.curtain__nudge-label {
			animation: curtain-fade 2.2s ease-in-out infinite;
		}
	}

	@keyframes curtain-pulse {
		0%,
		100% {
			transform: translateY(0) scale(1);
			box-shadow: 0 0 0 0 rgba(232, 213, 183, 0.5);
		}
		50% {
			transform: translateY(-6px) scale(1.05);
			box-shadow: 0 0 0 12px rgba(232, 213, 183, 0);
		}
	}

	@keyframes curtain-fade {
		0%,
		100% {
			opacity: 0.7;
		}
		50% {
			opacity: 1;
		}
	}
</style>

<script>
	import { audio } from "../lib/audio.ts";
	import { prefersReducedMotion } from "../lib/gsap.ts";

	declare global {
		interface Window {
			__weddingAudioSrc?: string;
		}
	}

	function run() {
		const curtain = document.getElementById("curtain");
		const video = document.getElementById(
			"curtain-video"
		) as HTMLVideoElement | null;
		const nudge = document.getElementById("curtain-nudge");
		if (!curtain || !video || !nudge) return;

		if (window.__weddingAudioSrc) {
			audio.init(window.__weddingAudioSrc);
		}

		let opened = false;
		let textCueFired = false;

		const fireTextCue = () => {
			if (textCueFired) return;
			textCueFired = true;
			window.dispatchEvent(new CustomEvent("wedding:curtain-click"));
		};

		const TEXT_CUE_TIME = 1.5;

		const handleTimeUpdate = () => {
			if (video.currentTime >= TEXT_CUE_TIME) fireTextCue();
		};

		const finish = () => {
			fireTextCue();
			curtain.dataset.state = "hidden";
			document.documentElement.classList.remove("is-intro-locked");
			document.body.classList.remove("is-intro-locked");
			window.setTimeout(() => {
				curtain.setAttribute("aria-hidden", "true");
			}, 1100);
		};

		const open = () => {
			if (opened) return;
			opened = true;

			window.dispatchEvent(new CustomEvent("wedding:curtain-open"));

			if (!prefersReducedMotion()) {
				audio.play();
			}

			curtain.dataset.state = "playing";

			video.addEventListener("ended", finish, { once: true });
			video.addEventListener("timeupdate", handleTimeUpdate);

			const playPromise = video.play();
			if (playPromise && typeof playPromise.catch === "function") {
				playPromise.catch(() => {
					window.setTimeout(finish, 400);
				});
			}

			window.setTimeout(() => {
				if (curtain.dataset.state === "playing") finish();
			}, 12000);
		};

		document.documentElement.classList.add("is-intro-locked");
		document.body.classList.add("is-intro-locked");

		curtain.addEventListener("click", open);
		nudge.addEventListener("click", open);
		nudge.addEventListener("keydown", e => {
			if (e.key === "Enter" || e.key === " ") {
				e.preventDefault();
				open();
			}
		});
	}

	if (document.readyState !== "loading") run();
	else document.addEventListener("DOMContentLoaded", run);
</script>
