---
import { ArrowDown } from "@lucide/astro";
import { wedding } from "../config/wedding.ts";

const curtainOpenImage = "/assets/curtain-open.jpg";
---

<section
	class='invitation relative grid place-items-center overflow-hidden bg-bg min-h-dvh'
	aria-label='Invitation'
>
	<img
		class='invitation__backdrop absolute inset-0 w-full! h-full! object-cover z-0'
		src={curtainOpenImage}
		alt=''
		aria-hidden='true'
		fetchpriority='high'
	/>

	<div
		class='container-narrow text-center flex flex-col items-center relative z-60 text-accent pointer-events-none mt-40 md:mt-0'
	>
		<p
			class='invitation__eyebrow font-serif uppercase text-accent font-medium mb-6 mx-auto max-w-[35ch] md:max-w-88'
			data-reveal
		>
			You are cordially invited to celebrate the wedding of
		</p>

		<h1
			class='invitation__names text-accent font-bold flex flex-col leading-tight items-center'
			data-reveal
		>
			<span class='script italic'>{wedding.couple.one}</span>
			<span class='invitation__amp script'>&amp;</span>
			<span class='script italic'>{wedding.couple.two}</span>
		</h1>
		<p
			class='invitation__copy font-serif font-medium uppercase text-accent tracking-[0.12em] leading-relaxed max-w-[80%] md:max-w-160 pt-8 md:pt-0 mx-auto'
			data-reveal
		>
			{wedding.invitationCopy}
		</p>
	</div>

	<div
		class='invitation__scroll-wrap absolute left-0 right-0 z-60 flex justify-center pointer-events-none'
		aria-hidden='true'
		data-reveal
	>
		<div
			class='invitation__scroll flex flex-col items-center gap-1 text-accent'
		>
			<span
				class='invitation__scroll-label font-serif font-bold text-[0.7rem] tracking-[0.32em] uppercase'
				>Scroll</span
			>
			<ArrowDown />
		</div>
	</div>
</section>

<style>
	/* min-h with svh fallback + clamp() padding — neither expressible as utilities. */
	.invitation {
		padding: clamp(var(--space-7), 10vw, var(--space-9))
			clamp(var(--space-4), 5vw, var(--space-7));
	}

	/* GSAP reads these as the from-state and tweens to opacity:1/y:0 on cue. */
	[data-reveal] {
		opacity: 0;
		transform: translateY(20px);
	}

	.invitation__eyebrow {
		font-size: clamp(0.6rem, 1.5vw, 0.78rem);
	}

	.invitation__names {
		font-size: clamp(0.2rem, 5vw, 1rem);
		line-height: 1;
		margin: 0 0 var(--space-6);
	}

	.invitation__amp {
		font-size: clamp(2rem, 7vw, 3rem);
		font-weight: 400;
		opacity: 0.9;
		margin: 0.05em 0;
	}

	.invitation__copy {
		font-size: clamp(0.7rem, 1.7vw, 0.9rem);
	}

	.invitation__scroll-wrap {
		bottom: clamp(1rem, 2.4svw, 4rem);
	}

	.invitation__scroll {
		animation: invitation-levitate 2.4s ease-in-out infinite;
	}

	@keyframes invitation-levitate {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-10px);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.invitation__scroll {
			animation: none;
		}
	}

	@media (min-width: 768px) {
		.invitation__names {
			font-size: clamp(5rem, 12vw, 9rem);
		}
	}
</style>

<script>
	import { getGsap, prefersReducedMotion } from "../lib/gsap.ts";

	function run() {
		const reduce = prefersReducedMotion();
		const { gsap } = getGsap();
		const targets = document.querySelectorAll<HTMLElement>(
			".invitation [data-reveal]"
		);

		if (reduce) {
			gsap.set(targets, { opacity: 1, y: 0 });
			return;
		}

		// Text animates in during video playback, above the curtain overlay.
		// Backdrop is static — it's revealed simply by the curtain overlay
		// fading out at the end of the video.
		const revealText = () => {
			gsap.to(targets, {
				opacity: 1,
				y: 0,
				duration: 1.1,
				ease: "power3.out",
				stagger: 0.1
			});
		};

		window.addEventListener("wedding:curtain-click", revealText, {
			once: true
		});
	}

	if (document.readyState !== "loading") run();
	else document.addEventListener("DOMContentLoaded", run);
</script>
