---
import { wedding } from "../config/wedding.ts";
---

<section class="dress-code section bg-bg text-center" aria-label="Dress code">
  <div class="container-narrow text-center">
    <p class="eyebrow">What to wear</p>
    <h2>{wedding.dressCode.title}</h2>
    <span class="divider"></span>
    <p class="dress-code__desc text-ink-soft max-w-lg mx-auto italic">
      {wedding.dressCode.description}
    </p>

    <ul class="dress-code__palette list-none flex gap-4 justify-center p-0 mt-8 mb-0" aria-label="Suggested palette">
      {wedding.dressCode.palette.map((hex) => (
        <li
          style={`--swatch:${hex}`}
          title={hex}
          class="w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-[var(--swatch)] transition-transform duration-[350ms] ease-out hover:-translate-y-1 hover:scale-105"
        ></li>
      ))}
    </ul>
  </div>
</section>

<style>
  .dress-code__desc {
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
  }

  /* Composite shadow (outer + inset highlight) — keeping in CSS for readability. */
  .dress-code__palette li {
    box-shadow: var(--shadow-sm), inset 0 0 0 2px rgba(255, 255, 255, 0.4);
  }
</style>

<script>
  import { getGsap, prefersReducedMotion } from "../lib/gsap.ts";

  function run() {
    if (prefersReducedMotion()) return;
    const { gsap } = getGsap();
    gsap.from(".dress-code__palette li", {
      scrollTrigger: { trigger: ".dress-code__palette", start: "top 85%" },
      opacity: 0,
      y: 16,
      scale: 0.8,
      duration: 0.6,
      ease: "back.out(1.6)",
      stagger: 0.08,
    });
  }

  if (document.readyState !== "loading") run();
  else document.addEventListener("DOMContentLoaded", run);
</script>
