---
import { wedding } from "../config/wedding.ts";
---

<section class="directions section" aria-label="Directions">
  <div class="container text-center">
    <p class="eyebrow">How to get there</p>
    <h2>{wedding.venue.name}</h2>
    <span class="divider"></span>
    <p class="directions__notes">{wedding.directions.notes}</p>

    <div class="directions__map" data-reveal>
      <iframe
        src={wedding.venue.mapEmbedUrl}
        title={`Map to ${wedding.venue.name}`}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>

    <a class="directions__link" href={wedding.venue.mapLinkUrl} target="_blank" rel="noopener noreferrer">
      Open in Google Maps ↗
    </a>
  </div>
</section>

<style>
  .directions {
    background: var(--color-bg);
    text-align: center;
  }

  .directions__notes {
    color: var(--color-ink-soft);
    font-style: italic;
    max-width: 36rem;
    margin: 0 auto var(--space-6);
  }

  .directions__map {
    position: relative;
    width: 100%;
    max-width: 48rem;
    aspect-ratio: 16 / 10;
    margin: 0 auto var(--space-5);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    background: var(--color-bg-deep);
  }

  .directions__map iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .directions__link {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: var(--space-3) var(--space-5);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-full);
    transition: background 0.2s var(--ease-out), color 0.2s var(--ease-out);
  }

  .directions__link:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }
</style>

<script>
  import { getGsap, prefersReducedMotion } from "../lib/gsap.ts";

  function run() {
    if (prefersReducedMotion()) return;
    const { gsap } = getGsap();
    gsap.from(".directions__map", {
      scrollTrigger: { trigger: ".directions__map", start: "top 80%" },
      opacity: 0,
      y: 30,
      duration: 0.9,
      ease: "power3.out",
    });
  }

  if (document.readyState !== "loading") run();
  else document.addEventListener("DOMContentLoaded", run);
</script>
