---
import { wedding } from "../config/wedding.ts";
---

<section class="directions section bg-bg text-center" aria-label="Directions">
  <div class="container text-center">
    <p class="eyebrow">How to get there</p>
    <h2>{wedding.venue.name}</h2>
    <span class="divider"></span>
    <p class="directions__notes text-ink-soft italic max-w-xl mx-auto mb-8">
      {wedding.directions.notes}
    </p>

    <div
      class="directions__map relative w-full max-w-3xl aspect-[16/10] mx-auto mb-6 rounded-lg overflow-hidden shadow-lg bg-bg-deep"
      data-reveal
    >
      <iframe
        class="absolute inset-0 w-full h-full border-0"
        src={wedding.venue.mapEmbedUrl}
        title={`Map to ${wedding.venue.name}`}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>

    <a
      class="directions__link inline-block font-sans text-[0.8rem] tracking-[0.15em] uppercase py-3 px-6 border border-accent rounded-full transition-colors duration-200 ease-out hover:bg-accent hover:text-bg"
      href={wedding.venue.mapLinkUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      Open in Google Maps ↗
    </a>
  </div>
</section>

<script>
  import { getGsap, prefersReducedMotion } from "../lib/gsap.ts";

  function run() {
    if (prefersReducedMotion()) return;
    const { gsap } = getGsap();
    gsap.from(".directions__map", {
      scrollTrigger: { trigger: ".directions__map", start: "top 80%" },
      opacity: 0,
      y: 30,
      duration: 0.9,
      ease: "power3.out",
    });
  }

  if (document.readyState !== "loading") run();
  else document.addEventListener("DOMContentLoaded", run);
</script>
