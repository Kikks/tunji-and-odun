---
import { ArrowUpRight } from "@lucide/astro";
import { wedding } from "../config/wedding.ts";
---

<section
	class='directions section bg-accent-soft/1 text-center'
	aria-label='Directions'
>
	<div class='container flex flex-col items-center text-center'>
		<p class='eyebrow'>How to get there</p>
		<h2 class='script italic text-accent'>{wedding.venue.name}</h2>
		<span class='divider'></span>

		<div
			class='directions__map relative w-full max-w-3xl aspect-16/10 mx-auto mb-6 rounded-lg overflow-hidden shadow-lg bg-bg-deep'
			data-reveal
		>
			<iframe
				class='absolute inset-0 w-full h-full border-0'
				src={wedding.venue.mapEmbedUrl}
				title={`Map to ${wedding.venue.name}`}
				loading='lazy'
				referrerpolicy='no-referrer-when-downgrade'
				allowfullscreen></iframe>
		</div>

		<a
			class='directions__link flex items-center gap-2 font-sans font-bold text-[0.8rem] tracking-[0.15em] uppercase py-3 px-6 text-accent! border border-accent! rounded-full duration-300 ease-out hover:bg-accent! hover:text-white!'
			href={wedding.venue.mapLinkUrl}
			target='_blank'
			rel='noopener noreferrer'
		>
			<span>Open in Google Maps</span>
			<ArrowUpRight />
		</a>
	</div>
</section>

<script>
	import { getGsap, prefersReducedMotion } from "../lib/gsap.ts";

	function run() {
		if (prefersReducedMotion()) return;
		const { gsap } = getGsap();
		gsap.from(
			[".directions .eyebrow", ".directions h2", ".directions .divider"],
			{
				scrollTrigger: { trigger: ".directions", start: "top 80%" },
				opacity: 0,
				y: 24,
				duration: 0.9,
				ease: "power3.out",
				stagger: 0.12
			}
		);
		gsap.from(".directions__map", {
			scrollTrigger: { trigger: ".directions__map", start: "top 80%" },
			opacity: 0,
			y: 30,
			duration: 0.9,
			ease: "power3.out"
		});
		gsap.from(".directions__link", {
			scrollTrigger: { trigger: ".directions__link", start: "top 90%" },
			opacity: 0,
			y: 16,
			duration: 0.8,
			ease: "power3.out"
		});
	}

	if (document.readyState !== "loading") run();
	else document.addEventListener("DOMContentLoaded", run);
</script>
