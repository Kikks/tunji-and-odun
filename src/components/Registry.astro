---
import { Copy } from "@lucide/astro";
import { wedding } from "../config/wedding.ts";
---

<section class='registry section bg-bg-deep text-center' aria-label='Registry'>
	<div class='container-narrow flex flex-col items-center text-center'>
		<p class='eyebrow'>Registry</p>
		<h2 class='script italic registry__heading text-accent mb-4'>
			With all our love
		</h2>
		<span class='divider'></span>
		<p class='registry__message text-ink-soft max-w-136 mx-auto mb-8'>
			{wedding.registry.message}
		</p>

		<div class='registry__card bg-bg rounded-lg text-left max-w-lg mx-auto'>
			<dl class='m-0 grid gap-6'>
				<div class='registry__row grid gap-1'>
					<dt
						class='font-sans text-[0.7rem] tracking-[0.2em] uppercase text-accent'
					>
						Bank Name
					</dt>
					<dd class='m-0 text-lg text-ink break-all'>
						{wedding.registry.bank}
					</dd>
				</div>
				<div class='registry__row grid gap-1'>
					<dt
						class='font-sans text-[0.7rem] tracking-[0.2em] uppercase text-accent'
					>
						Account Name
					</dt>
					<dd class='m-0 text-lg text-ink break-all'>
						{wedding.registry.accountName}
					</dd>
				</div>
				<div class='registry__row grid gap-1'>
					<dt
						class='font-sans text-[0.7rem] tracking-[0.2em] uppercase text-accent'
					>
						Account Number
					</dt>
					<dd
						class='registry__iban w-full m-0 text-lg text-ink break-all flex items-center justify-between gap-10 flex-wrap font-sans tracking-[0.04em]'
					>
						<span id='account-number-value'
							>{wedding.registry.accountNumber}</span
						>
						<button
							type='button'
							class='registry__copy inline-flex items-center gap-2 py-2! px-3! rounded-full bg-accent/10 text-accent font-sans text-xs tracking-widest uppercase'
							id='copy-account-number'
							aria-label='Copy account number'
						>
							<Copy size={14} class='text-sm' />
							<span class='text-xs'>Copy</span>
						</button>
					</dd>
				</div>
			</dl>
		</div>
	</div>
</section>

<style>
	.registry__heading {
		font-size: clamp(2.5rem, 7vw, 4rem);
	}

	/* clamp() padding on the card — Tailwind can't express fluid padding. */
	.registry__card {
		padding: clamp(var(--space-5), 5vw, var(--space-7));
	}

	.registry__iban {
		font-variant-numeric: tabular-nums;
	}

	/* Multi-property transition + state class (.is-copied) — keep in CSS. */
	.registry__copy {
		transition:
			transform 0.2s var(--ease-out),
			background 0.2s var(--ease-out);
	}

	.registry__copy:hover {
		background: var(--color-accent-soft);
		transform: translateY(-1px);
	}

	.registry__copy.is-copied {
		background: var(--color-gold);
		color: var(--color-ink);
	}
</style>

<script>
	import { getGsap, prefersReducedMotion } from "../lib/gsap.ts";

	function run() {
		const button = document.getElementById("copy-account-number");
		const value = document.getElementById("account-number-value");
		const label = button?.querySelector<HTMLElement>("span");
		if (button && value && label) {
			button.addEventListener("click", async () => {
				try {
					await navigator.clipboard.writeText(value.textContent?.trim() ?? "");
					button.classList.add("is-copied");
					label.textContent = "Copied";
					window.setTimeout(() => {
						button.classList.remove("is-copied");
						label.textContent = "Copy";
					}, 5000);
				} catch {
					label.textContent = "Press ⌘C";
				}
			});
		}

		if (prefersReducedMotion()) return;
		const { gsap } = getGsap();
		gsap.from(
			[
				".registry .eyebrow",
				".registry__heading",
				".registry .divider",
				".registry__message",
			],
			{
				scrollTrigger: { trigger: ".registry", start: "top 80%" },
				opacity: 0,
				y: 24,
				duration: 0.9,
				ease: "power3.out",
				stagger: 0.12,
			},
		);
		gsap.from(".registry__card", {
			scrollTrigger: { trigger: ".registry__card", start: "top 85%" },
			opacity: 0,
			y: 32,
			scale: 0.96,
			duration: 1.0,
			ease: "power3.out",
		});
		gsap.from(".registry__row", {
			scrollTrigger: { trigger: ".registry__card", start: "top 80%" },
			opacity: 0,
			y: 16,
			duration: 0.7,
			ease: "power3.out",
			stagger: 0.1,
			delay: 0.3,
		});
	}

	if (document.readyState !== "loading") run();
	else document.addEventListener("DOMContentLoaded", run);
</script>
