---
import { wedding } from "../config/wedding.ts";
---

<section class="registry section bg-bg-deep text-center" aria-label="Registry">
  <div class="container-narrow text-center">
    <p class="eyebrow">Registry</p>
    <h2 class="script registry__heading text-accent mb-4">With all our love</h2>
    <span class="divider"></span>
    <p class="registry__message text-ink-soft italic max-w-[34rem] mx-auto mb-8">{wedding.registry.message}</p>

    <div class="registry__card bg-bg rounded-lg shadow-md text-left max-w-lg mx-auto">
      <dl class="m-0 grid gap-6">
        <div class="registry__row grid gap-1">
          <dt class="font-sans text-[0.7rem] tracking-[0.2em] uppercase text-gold">Account holder</dt>
          <dd class="m-0 text-lg text-ink break-all">{wedding.registry.accountHolder}</dd>
        </div>
        <div class="registry__row grid gap-1">
          <dt class="font-sans text-[0.7rem] tracking-[0.2em] uppercase text-gold">IBAN</dt>
          <dd class="registry__iban m-0 text-lg text-ink break-all flex items-center gap-3 flex-wrap font-sans tracking-[0.04em]">
            <span id="iban-value">{wedding.registry.iban}</span>
            <button
              type="button"
              class="registry__copy inline-flex items-center gap-2 py-2 px-3 rounded-full bg-accent text-bg font-sans text-xs tracking-[0.1em] uppercase"
              id="copy-iban"
              aria-label="Copy IBAN"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <span class="registry__copy-label">Copy</span>
            </button>
          </dd>
        </div>
        <div class="registry__row grid gap-1">
          <dt class="font-sans text-[0.7rem] tracking-[0.2em] uppercase text-gold">Reference</dt>
          <dd class="m-0 text-lg text-ink break-all">{wedding.registry.reference}</dd>
        </div>
      </dl>
    </div>
  </div>
</section>

<style>
  .registry__heading {
    font-size: clamp(2.5rem, 7vw, 4rem);
  }

  /* clamp() padding on the card — Tailwind can't express fluid padding. */
  .registry__card {
    padding: clamp(var(--space-5), 5vw, var(--space-7));
  }

  .registry__iban {
    font-variant-numeric: tabular-nums;
  }

  /* Multi-property transition + state class (.is-copied) — keep in CSS. */
  .registry__copy {
    transition:
      transform 0.2s var(--ease-out),
      background 0.2s var(--ease-out);
  }

  .registry__copy:hover {
    background: var(--color-accent-soft);
    transform: translateY(-1px);
  }

  .registry__copy.is-copied {
    background: var(--color-gold);
    color: var(--color-ink);
  }
</style>

<script>
  function run() {
    const button = document.getElementById("copy-iban");
    const value = document.getElementById("iban-value");
    const label = button?.querySelector<HTMLElement>(".registry__copy-label");
    if (!button || !value || !label) return;

    button.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(value.textContent?.trim() ?? "");
        button.classList.add("is-copied");
        label.textContent = "Copied";
        window.setTimeout(() => {
          button.classList.remove("is-copied");
          label.textContent = "Copy";
        }, 1800);
      } catch {
        label.textContent = "Press ⌘C";
      }
    });
  }

  if (document.readyState !== "loading") run();
  else document.addEventListener("DOMContentLoaded", run);
</script>
