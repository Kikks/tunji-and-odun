---
import { wedding } from "../config/wedding.ts";
---

<section class="menu section" aria-label="Menu">
  <div class="container-narrow text-center">
    <p class="eyebrow">Dinner</p>
    <h2>Menu</h2>
    <span class="divider"></span>

    <ol class="menu__list">
      {wedding.menu.map((item, i) => (
        <li class="menu__item" data-reveal>
          <span class="menu__index">{String(i + 1).padStart(2, "0")}</span>
          <div class="menu__body">
            <h3 class="menu__title">{item.title}</h3>
            <p class="menu__desc">{item.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .menu {
    background: var(--color-bg-deep);
    text-align: center;
  }

  .menu__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-5);
    text-align: left;
  }

  .menu__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    align-items: baseline;
    padding-bottom: var(--space-4);
    border-bottom: 1px solid rgba(107, 30, 30, 0.15);
  }

  .menu__item:last-child {
    border-bottom: none;
  }

  .menu__index {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--color-gold);
  }

  .menu__title {
    font-size: clamp(1.25rem, 3vw, 1.625rem);
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .menu__desc {
    color: var(--color-ink-soft);
    font-style: italic;
    margin: 0;
  }
</style>

<script>
  import { getGsap, prefersReducedMotion } from "../lib/gsap.ts";

  function run() {
    if (prefersReducedMotion()) return;
    const { gsap, ScrollTrigger } = getGsap();
    gsap.from(".menu .menu__item", {
      scrollTrigger: { trigger: ".menu__list", start: "top 80%" },
      opacity: 0,
      y: 20,
      duration: 0.7,
      ease: "power3.out",
      stagger: 0.1,
    });
  }

  if (document.readyState !== "loading") run();
  else document.addEventListener("DOMContentLoaded", run);
</script>
