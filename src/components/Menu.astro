---
import { wedding } from "../config/wedding.ts";
---

<section class="menu section bg-bg-deep text-center" aria-label="Menu">
  <div class="container-narrow text-center">
    <p class="eyebrow">Dinner</p>
    <h2>Menu</h2>
    <span class="divider"></span>

    <ol class="menu__list list-none m-0 p-0 grid gap-6 text-left">
      {wedding.menu.map((item, i) => (
        <li
          class="menu__item grid grid-cols-[auto_1fr] gap-4 items-baseline pb-4 border-b border-accent/15 last:border-b-0"
          data-reveal
        >
          <span class="menu__index font-sans text-xs tracking-[0.2em] text-gold">
            {String(i + 1).padStart(2, "0")}
          </span>
          <div class="menu__body">
            <h3 class="menu__title text-accent mb-2">{item.title}</h3>
            <p class="menu__desc text-ink-soft italic m-0">{item.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .menu__title {
    font-size: clamp(1.25rem, 3vw, 1.625rem);
  }
</style>

<script>
  import { getGsap, prefersReducedMotion } from "../lib/gsap.ts";

  function run() {
    if (prefersReducedMotion()) return;
    const { gsap, ScrollTrigger } = getGsap();
    gsap.from(".menu .menu__item", {
      scrollTrigger: { trigger: ".menu__list", start: "top 80%" },
      opacity: 0,
      y: 20,
      duration: 0.7,
      ease: "power3.out",
      stagger: 0.1,
    });
  }

  if (document.readyState !== "loading") run();
  else document.addEventListener("DOMContentLoaded", run);
</script>
